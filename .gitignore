# NixOS secrets (plain text - DO NOT COMMIT)
nixos/secrets/*
!nixos/secrets/.gitignore
!nixos/secrets/*.age          # ← ALLOW encrypted .age files
nixos/*.secret
nixos/hardware-configuration.nix

# K3s secrets (unencrypted - DO NOT COMMIT)
k3s-manifest/*/secrets/
k3s-manifest/*/*.secret
k3s-manifest/*/*-secret.yaml
k3s-manifest/*/secret.yaml
*.secret.yaml

# Kubernetes secrets 
kubernetes/*/*-secret.yaml
kubernetes/*/secret.yaml
kubernetes/*/*/secret.yaml
kubernetes/*/*-credentials.yaml
kubernetes/flux/bootstrap/git-credentials-secret.yaml

# But ALLOW encrypted files
!k3s-manifest/*/*.enc.yaml    # SOPS encrypted
!*.enc.yaml                   # SOPS encrypted (COMMIT THESE)
!nixos/secrets/*.age          # agenix encrypted (duplicate for clarity)

# Cloudflare plain text tokens
k3s-manifest/cloudflare/*-credentials.yaml
k3s-manifest/cloudflare/tunnel-credentials.json

# General plain text secret patterns
*-token.yaml
*-password.yaml
*.key
*.pem

# OS files
.DS_Store
Thumbs.db
