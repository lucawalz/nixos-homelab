{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard"
  ],
  "nix": {
    "enabled": true
  },
  "flux": {
    "enabled": true
  },
  "github-actions": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Group all nixpkgs flake updates together",
      "matchManagers": ["nix"],
      "groupName": "nixpkgs"
    },
    {
      "description": "Group infrastructure Helm charts together",
      "matchManagers": ["flux"],
      "groupName": "infrastructure charts",
      "schedule": ["on sunday"],
      "matchPackageNames": [
        "/cert-manager/",
        "/traefik/",
        "/longhorn/",
        "/kube-prometheus-stack/",
        "/redis-operator/"
      ]
    },
    {
      "description": "App charts updated individually for easier review",
      "matchManagers": ["flux"],
      "groupName": "app charts",
      "matchPackageNames": [
        "/n8n/",
        "/it-tools/",
        "/tekton/"
      ]
    }
  ]
}
